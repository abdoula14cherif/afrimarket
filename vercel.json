{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
// Fichier: vercel.json à la racine de votre projet
{
  "rewrites": [
    {
      "source": "/ref/:code",
      "destination": "/inscription.html?ref=:code"
    }
  ],
  "redirects": [
    {
      "source": "/ref/:code",
      "destination": "/inscription.html?ref=:code",
      "permanent": true
    }
  ]
}