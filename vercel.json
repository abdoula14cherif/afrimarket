{
  "rewrites": [
    {
      "source": "/ref/:code",
      "destination": "/index.html"
    },
    {
      "source": "/parrainage/:code",
      "destination": "/index.html"
    },
    {
      "source": "/invitation/:code",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/inscription",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/signup",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/register",
      "destination": "/index.html",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/index.html",
      "permanent": false
    }
  ],
  "cleanUrls": true
}