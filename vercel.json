{
  "rewrites": [
    {
      "source": "/ref/:code",
      "destination": "/inscription.html"
    },
    {
      "source": "/parrainage/:code",
      "destination": "/inscription.html"
    },
    {
      "source": "/invitation/:code",
      "destination": "/inscription.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/accueil.html",
      "permanent": false
    }
  ],
  "cleanUrls": false
}